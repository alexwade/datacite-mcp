# DataCite MCP Server Environment Variables

# User-Agent URL — included in HTTP requests to DataCite for identification
MCP_USER_AGENT_URL=https://github.com/datacite-mcp

# Contact email included in User-Agent (optional but recommended per DataCite polite pool)
MCP_USER_AGENT_EMAIL=

# Max requests per second to the DataCite API (default: 10)
DATACITE_RATE_LIMIT_RPS=10

# How long to cache individual DOI lookups, in seconds (default: 1 hour)
CACHE_DOI_TTL_SECONDS=3600

# How long to cache search results, in seconds (default: 5 minutes)
CACHE_SEARCH_TTL_SECONDS=300

# How long to cache static data (resource types, providers, clients), in seconds (default: 24 hours)
CACHE_STATIC_TTL_SECONDS=86400
